{
  "name": "lumina-gallery",
  "version": "0.1.0",
  "description": "Beautiful photo gallery",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "package:win": "vite build && electron-builder --win --config.directories.output=release/windows",
    "package:mac": "vite build && electron-builder --mac --config.directories.output=release/macos",
    "package:linux": "vite build && electron-builder --linux --config.directories.output=release/linux",
    "preview": "vite preview",
    "vite": "vite"
  },
  "build": {
    "appId": "com.lumina.gallery",
    "productName": "Lumina Gallery",
    "directories": {
      "buildResources": "build-assets"
    },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "public/icon.icns",
      "identity": null,
      "darkModeSupport": true
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
